@model PollBuilder.Web.ViewModels.Admin.DashboardVM

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Admin Dashboard</h2>
            <p class="text-muted mb-0">
                Overview of the PollBuilder system
            </p>
        </div>
    </div>

    <!-- Statistic Cards -->

    <div class="row g-4 mb-5">

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Total Users
                            </small>

                            <h2 class="fw-bold mt-2">
                                @Model.TotalUsers
                            </h2>

                        </div>

                        <div class="fs-1">
                            👤
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Total Polls
                            </small>

                            <h2 class="fw-bold mt-2">
                                @Model.TotalPolls
                            </h2>

                        </div>

                        <div class="fs-1">
                            📋
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Total Votes
                            </small>

                            <h2 class="fw-bold mt-2">
                                @Model.TotalVotes
                            </h2>

                        </div>

                        <div class="fs-1">
                            🗳️
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card border-0 shadow-sm">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Active Polls
                            </small>

                            <h2 class="fw-bold mt-2">
                                @Model.ActivePolls
                            </h2>

                        </div>

                        <div class="fs-1">
                            ✅
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Tables -->

    <div class="row">

        <!-- Top Users -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-primary text-white">

                    <h5 class="mb-0">
                        Top Users
                    </h5>

                </div>

                <div class="card-body p-0">

                    <table class="table table-hover mb-0">

                        <thead>

                            <tr>

                                <th>User</th>

                                <th>Email</th>

                                <th class="text-center">Polls</th>

                                <th class="text-center">Votes</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model.TopUsers)
                            {

                                <tr>

                                    <td>

                                        <strong>
                                            @item.UserName
                                        </strong>

                                    </td>

                                    <td>
                                        @item.Email
                                    </td>

                                    <td class="text-center">

                                        <span class="badge bg-success">
                                            @item.PollCount
                                        </span>

                                    </td>

                                    <td class="text-center">

                                        <span class="badge bg-primary">
                                            @item.VoteCount
                                        </span>

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

        <!-- Recent Polls -->

        <div class="col-lg-6">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-success text-white">

                    <h5 class="mb-0">
                        Recent Polls
                    </h5>

                </div>

                <div class="card-body p-0">

                    <table class="table table-hover mb-0">

                        <thead>

                            <tr>

                                <th>Title</th>

                                <th>Votes</th>

                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var poll in Model.RecentPolls)
                            {

                                <tr>

                                    <td>

                                        <strong>

                                            @poll.Title

                                        </strong>

                                        <br />

                                        <small class="text-muted">

                                            @poll.CreatedAt.ToString("dd/MM/yyyy")

                                        </small>

                                    </td>

                                    <td>

                                        <span class="badge bg-info">

                                            @poll.VoteCount

                                        </span>

                                    </td>

                                    <td>

                                        @if (poll.IsClosed)
                                        {
                                            <span class="badge bg-danger">
                                                Closed
                                            </span>
                                        }
                                        else if (poll.ExpiredAt.HasValue &&
                                                 poll.ExpiredAt < DateTime.UtcNow)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                Expired
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                Active
                                            </span>
                                        }

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>