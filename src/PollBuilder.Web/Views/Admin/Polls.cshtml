@model IEnumerable<PollBuilder.Web.ViewModels.Admin.AdminPollVM>

@{
    ViewData["Title"] = "Poll Management";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">Poll Management</h2>
            <p class="text-muted">
                Manage all polls in the system
            </p>
        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <form method="get">

                <div class="row mb-4">

                    <div class="col-md-5">

                        <input class="form-control"
                               name="search"
                               placeholder="Search poll..." />

                    </div>

                    <div class="col-auto">

                        <button class="btn btn-primary">

                            Search

                        </button>

                    </div>

                </div>

            </form>

            <table class="table table-hover align-middle">

                <thead class="table-light">

                    <tr>

                        <th>Title</th>

                        <th>Created</th>

                        <th>Votes</th>

                        <th>Status</th>

                        <th class="text-center">Action</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var poll in Model)
                    {

                        <tr id="poll-@poll.Id">

                            <td>

                                <strong>

                                    @poll.Title

                                </strong>

                                <br />

                                <small class="text-muted">

                                    @poll.Description

                                </small>

                            </td>

                            <td>

                                @poll.CreatedAt.ToString("dd/MM/yyyy")

                            </td>

                            <td>

                                <span class="badge bg-primary">

                                    @poll.VoteCount

                                </span>

                            </td>

                            <td>

                                @if (poll.IsClosed)
                                {
                                    <span class="badge bg-danger">

                                        Closed

                                    </span>
                                }
                                else if (poll.ExpiredAt.HasValue &&
                                         poll.ExpiredAt < DateTime.UtcNow)
                                {
                                    <span class="badge bg-warning text-dark">

                                        Expired

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">

                                        Active

                                    </span>
                                }

                            </td>

                            <td class="text-center align-middle">

                                <div class="d-flex justify-content-center align-items-center gap-2">
                                    <a asp-controller="Vote"
                                       asp-action="Index"
                                       asp-route-id="@poll.Id"
                                       class="btn btn-sm btn-info">

                                        View

                                    </a>

                                    <form class="deleteForm"
                                          asp-controller="Poll"
                                          asp-action="Delete"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               class="pollId"
                                               value="@poll.Id" />

                                        <button type="button"
                                                class="btn btn-danger btn-sm btnDelete"
                                                data-id="@poll.Id">
                                            Delete
                                        </button>

                                    </form>
                                </div>

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

$(".btnDelete").click(function () {

    let id = $(this).data("id");

    Swal.fire({
        title: "Delete Poll?",
        text: "This action cannot be undone.",
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#dc3545",
        cancelButtonColor: "#6c757d",
        confirmButtonText: "Delete",
        cancelButtonText: "Cancel"
    }).then((r) => {

        if (!r.isConfirmed)
            return;

        console.log(id);

        $.post("/Admin/Delete",
            {
                id: id,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            function (result) {

                Swal.fire({
                    toast: true,
                    position: 'top-end',
                    icon: result.success ? 'success' : 'error',
                    title: result.message,
                    showConfirmButton: false,
                    timer: 1000
                }).then(() => {

                    if (result.success) {
                        location.reload();
                    }

                });

            });

    });

});
    </script>

}