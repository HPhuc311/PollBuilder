<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Poll Builder</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">

        <div class="container">

            <a class="navbar-brand fw-bold"
               asp-controller="Home"
               asp-action="Index">

                <i class="bi bi-bar-chart-fill"></i>

                Poll Builder

            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbar">

                <span class="navbar-toggler-icon"></span>

            </button>

            <div class="collapse navbar-collapse"
                 id="navbar">

                <ul class="navbar-nav ms-auto">

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-controller="Home"
                           asp-action="Index">

                            <i class="bi bi-house-door"></i>

                            Home

                        </a>

                    </li>

                    <li class="nav-item">

                        <a class="nav-link"
                           asp-controller="Poll"
                           asp-action="Index">

                            <i class="bi bi-list-ul"></i>

                            Polls

                        </a>

                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="About">
                            About
                        </a>
                    </li>

                </ul>

                <partial name="_LoginPartial" />

            </div>

        </div>

    </nav>

    <!-- Main -->

    <main>

        <div class="container py-5">

            @RenderBody()

        </div>

    </main>

    <!-- Footer -->

    <footer class="footer mt-auto">

        <div class="container">

            <div class="row">

                <div class="col-md-6">

                    <h5 class="fw-bold">

                        Poll Builder

                    </h5>

                    <p>

                        Online Polling System built with

                        ASP.NET Core MVC, CQRS, SignalR and SQL Server.

                    </p>

                </div>

                <div class="col-md-3">

                    <h6>

                        Navigation

                    </h6>

                    <ul class="list-unstyled">

                        <li>

                            <a asp-controller="Home"
                               asp-action="Index">

                                Home

                            </a>

                        </li>

                        <li>

                            <a asp-controller="Poll"
                               asp-action="Index">

                                Polls

                            </a>

                        </li>

                        <li>

                            <a asp-controller="Poll"
                               asp-action="Create">

                                Create

                            </a>

                        </li>

                    </ul>

                </div>

                <div class="col-md-3">

                    <h6>

                        Technologies

                    </h6>

                    <span class="badge bg-primary">ASP.NET</span>

                    <span class="badge bg-success">SignalR</span>

                    <span class="badge bg-dark">CQRS</span>

                    <span class="badge bg-secondary">SQL</span>

                </div>  

            </div>

            <hr />

            <div class="text-center">

                © @DateTime.Now.Year

                Poll Builder

                | Advanced Microservices Development

            </div>

        </div>

    </footer>

    <div class="toast-container position-fixed top-0 end-0 p-3">

        <div id="liveToast"
             class="toast align-items-center border-0"
             role="alert">

            <div class="d-flex">

                <div class="toast-body"
                     id="toastMessage">
                </div>

                <button class="btn-close me-2 m-auto"
                        data-bs-dismiss="toast">
                </button>

            </div>

        </div>

    </div>

    @if (TempData["ToastMessage"] != null)
    {
        <script>

                document.addEventListener("DOMContentLoaded", function () {

                    const toast = document.getElementById("liveToast");

                    toast.classList.remove(
                        "text-bg-success",
                        "text-bg-danger",
                        "text-bg-warning",
                        "text-bg-info"
                    );

                    toast.classList.add("text-bg-" + "@TempData["ToastType"]");

                    document.getElementById("toastMessage").innerHTML =
                        "@TempData["ToastMessage"]";

                    new bootstrap.Toast(toast).show();

                });

        </script>
    }

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", false)

</body>

</html>