@{
    ViewData["Title"] = "Home";
}

<!-- Hero -->

<section class="hero-section">

    <div class="row align-items-center">

        <div class="col-lg-6">

            <span class="badge bg-primary px-3 py-2 mb-3">
                ASP.NET Core • CQRS • SignalR
            </span>

            <h1 class="display-4 fw-bold mb-3">

                Build Online Polls

                <span class="text-primary">In Seconds</span>

            </h1>

            <p class="lead text-muted mb-4">

                Create interactive polls, collect votes from everyone,
                and display live results instantly using SignalR.

            </p>

            <a asp-controller="Poll"
               asp-action="Create"
               class="btn btn-primary btn-lg me-2">

                <i class="bi bi-plus-circle"></i>

                Create Poll

            </a>

            <a asp-controller="Poll"
               asp-action="Index"
               class="btn btn-outline-primary btn-lg">

                <i class="bi bi-list-task"></i>

                Browse Polls

            </a>

        </div>

        <div class="col-lg-6 text-center"> </div>

    </div>

</section>

<!-- Statistics -->

<section class="mt-5">

    <div class="row g-4">

        <div class="col-md-3">

            <div class="card dashboard-card shadow-sm">

                <div class="card-body">

                    <i class="bi bi-bar-chart dashboard-icon"></i>

                    <h2>100+</h2>

                    <p>Total Polls</p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card dashboard-card shadow-sm">

                <div class="card-body">

                    <i class="bi bi-check2-square dashboard-icon"></i>

                    <h2>2500+</h2>

                    <p>Votes</p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card dashboard-card shadow-sm">

                <div class="card-body">

                    <i class="bi bi-broadcast dashboard-icon"></i>

                    <h2>Live</h2>

                    <p>SignalR</p>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card dashboard-card shadow-sm">

                <div class="card-body">

                    <i class="bi bi-server dashboard-icon"></i>

                    <h2>SQL</h2>

                    <p>Database</p>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- Features -->

<section class="mt-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">

            Features

        </h2>

        <p class="text-muted">

            Everything you need to build a modern polling system.

        </p>

    </div>

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card feature-card shadow-sm">

                <div class="card-body text-center">

                    <i class="bi bi-plus-circle-fill feature-icon"></i>

                    <h4>Create Poll</h4>

                    <p>

                        Create unlimited polls with multiple options.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card feature-card shadow-sm">

                <div class="card-body text-center">

                    <i class="bi bi-hand-index-thumb-fill feature-icon"></i>

                    <h4>Vote Online</h4>

                    <p>

                        Share your poll and collect votes instantly.

                    </p>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card feature-card shadow-sm">

                <div class="card-body text-center">

                    <i class="bi bi-bar-chart-fill feature-icon"></i>

                    <h4>Live Result</h4>

                    <p>

                        Results update automatically with SignalR.

                    </p>

                </div>

            </div>

        </div>

    </div>

</section>
<!-- Quick Actions -->

<section class="mt-5 mb-5">

    <div class="text-center">

        <h2 class="fw-bold">

            Quick Actions

        </h2>

        <p class="text-muted">

            Start using Poll Builder now.

        </p>

    </div>

    <div class="row mt-4 g-3">

        <div class="col-md-4">

            <a asp-controller="Poll"
               asp-action="Create"
               class="btn btn-primary w-100 py-3">

                <i class="bi bi-plus-circle"></i>

                Create Poll

            </a>

        </div>

        <div class="col-md-4">

            <a asp-controller="Poll"
               asp-action="Index"
               class="btn btn-success w-100 py-3">

                <i class="bi bi-list-ul"></i>

                Browse Polls

            </a>

        </div>

        <div class="col-md-4">

            <a asp-controller="Home"
               asp-action="Privacy"
               class="btn btn-dark w-100 py-3">

                <i class="bi bi-info-circle"></i>

                About Project

            </a>

        </div>

    </div>

</section>