@{
    ViewData["Title"] = "About";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold text-primary">About PollBuilder</h1>
        <p class="lead text-muted">
            A modern online polling system built with ASP.NET Core using Clean Architecture and CQRS.
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h4 class="text-primary">📋 Project Overview</h4>
                    <p>
                        PollBuilder is an online polling platform that allows users to create,
                        share, and participate in surveys quickly using a unique short URL.
                    </p>

                    <p>
                        Poll results are updated instantly with SignalR and securely stored
                        in SQL Server using Entity Framework Core.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h4 class="text-success">🚀 Main Features</h4>

                    <ul class="list-group list-group-flush">
                        <li class="list-group-item">✅ Create online polls</li>
                        <li class="list-group-item">✅ Share via Short URL & QR Code</li>
                        <li class="list-group-item">✅ One vote per participant</li>
                        <li class="list-group-item">✅ Real-time results using SignalR</li>
                        <li class="list-group-item">✅ Secure Admin Login</li>
                        <li class="list-group-item">✅ Redis Cache</li>
                        <li class="list-group-item">✅ Rate Limiting</li>
                        <li class="list-group-item">✅ Docker Deployment</li>
                    </ul>

                </div>
            </div>
        </div>

    </div>

    <div class="row mt-4">

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">

                    <h4 class="text-warning">🛠 Technologies</h4>

                    <table class="table">
                        <tbody>
                            <tr>
                                <th>Framework</th>
                                <td>ASP.NET Core 10 MVC</td>
                            </tr>

                            <tr>
                                <th>Architecture</th>
                                <td>Clean Architecture + CQRS</td>
                            </tr>

                            <tr>
                                <th>Database</th>
                                <td>PostgreSQL</td>
                            </tr>

                            <tr>
                                <th>ORM</th>
                                <td>Entity Framework Core</td>
                            </tr>

                            <tr>
                                <th>Authentication</th>
                                <td>ASP.NET Core Identity</td>
                            </tr>

                            <tr>
                                <th>Real-time</th>
                                <td>SignalR</td>
                            </tr>

                            <tr>
                                <th>Cache</th>
                                <td>Redis</td>
                            </tr>

                            <tr>
                                <th>Container</th>
                                <td>Docker</td>
                            </tr>

                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">

                    <h4 class="text-danger">👨‍💻 Developer</h4>

                    <p><strong>Name:</strong> Hoàng Phúc + Minh Phú</p>

                    <p><strong>Project:</strong> PollBuilder</p>

                    <p><strong>Course:</strong> COMP1844 Coursework</p>

                    <p><strong>University:</strong> University of Greenwich Vietnam</p>

                    <hr />

                    <p class="text-muted">
                        PollBuilder was developed as an academic coursework project,
                        demonstrating modern ASP.NET Core development practices,
                        including Clean Architecture, CQRS, Redis, SignalR,
                        Docker deployment, and secure authentication.
                    </p>

                </div>
            </div>
        </div>

    </div>

</div>